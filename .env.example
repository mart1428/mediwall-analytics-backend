# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# Atlas connection string. Use a DEDICATED analytics user scoped to the
# mediwall_analytics database (see README §2) — do not reuse the website user.
# Note: leave the path empty (no /dbname) — the app picks the DB via MONGODB_DB.
MONGODB_URI=mongodb+srv://USER:PASSWORD@mediwall-001.2fbsb3c.mongodb.net/?retryWrites=true&w=majority&appName=MediWall-001

# Separate database on the same cluster. Keeps analytics isolated from the website DB.
MONGODB_DB=mediwall_analytics

# Shared secret the app sends as `x-api-key`. Generate a long random string.
# Leave blank ONLY for first local testing; set it before going live.
ANALYTICS_API_KEY=

# Built-in analytics dashboard (GET /dashboard), protected with HTTP Basic Auth —
# kept separate from ANALYTICS_API_KEY so the app's secret never lives in a browser.
# Leave DASHBOARD_PASSWORD blank ONLY for first local testing; SET IT before going
# live (the dashboard exposes feedback messages + contact emails). DASHBOARD_USER
# defaults to "admin".
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# Port the service listens on.
PORT=8080
